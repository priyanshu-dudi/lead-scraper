# ============================================================
# LeadForge Ultimate — Railway Environment Config
# ============================================================
# Only OPENAI_API_KEY is required. Everything else has smart defaults.

# ── REQUIRED ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── WHAT TO SCRAPE ────────────────────────────────────────────
# Comma-separated niches to scrape
SCRAPE_NICHES=dentist,restaurant,gym,salon,hotel,lawyer,real estate,clinic

# Comma-separated cities to target
SCRAPE_CITIES=Mumbai,Delhi,Bangalore,Chennai,Hyderabad,Pune,Jaipur,Ahmedabad,Kolkata,Surat

# Comma-separated states
SCRAPE_STATES=Maharashtra,Delhi,Karnataka,Tamil Nadu,Telangana,Rajasthan,Gujarat,West Bengal

# Country
SCRAPE_COUNTRY=India

# ── AUTO-START (set true for Railway — scrapes on server boot) ─
AUTO_START=true

# ── PERFORMANCE ───────────────────────────────────────────────
MAX_CONCURRENCY=8
REQUEST_DELAY_MIN=800
REQUEST_DELAY_MAX=2500
MAX_RETRIES=3
REQUEST_TIMEOUT=25000
CRAWL_DEPTH=3

# ── ENGINE ────────────────────────────────────────────────────
# Set to false on Railway (Playwright needs Docker setup)
PLAYWRIGHT_ENABLED=false

# ── AI ────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
USE_AI_EXTRACTION=true

# ── SERVER ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
