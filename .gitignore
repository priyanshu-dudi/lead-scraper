# ============================================================
# LeadForge Ultimate — .gitignore
# ============================================================

# ── Node.js ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
package-lock.json

# ── Environment (NEVER commit secrets) ────────────────────────
config/.env
.env
.env.local
.env.*.local

# ── Database files ─────────────────────────────────────────────
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Exported data (too large / personal data) ─────────────────
exports/*.csv
exports/*.json
exports/*.xlsx
logs/
*.log

# ── Playwright browser binaries (hundreds of MB) ───────────────
backend/node_modules/.cache/
**/ms-playwright/

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python
.venv/
venv/
env/
ENV/
dist/
build/
*.egg-info/
.eggs/

# ── Frontend build output ──────────────────────────────────────
frontend/dist/
frontend/.vite/
frontend/node_modules/

# ── OS & Editor files ──────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Keep these folders tracked (but not their contents) ────────
!exports/.gitkeep
!logs/.gitkeep
